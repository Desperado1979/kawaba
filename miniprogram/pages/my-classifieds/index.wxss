.page-my {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.tip {
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  color: #999999;
}

.list {
  padding: 0 24rpx 24rpx;
}

.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.row-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.5;
}

.status {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
}

.status-1 { background-color: #E8F5E9; color: #009543; }
.status-0 { background-color: #FFF8E1; color: #8D6E00; }
.status--1 { background-color: #FFEBEE; color: #CE1126; }

.meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999999;
}

.dot { margin: 0 10rpx; }

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.btn.light {
  background-color: #F5F5F5;
  color: #333333;
}

.btn.danger {
  background-color: #CE1126;
  color: #FFFFFF;
}

.empty, .load {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 26rpx;
}

