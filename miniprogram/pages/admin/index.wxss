.page-admin {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.login-card {
  margin: 32rpx 24rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
}

.login-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.login-input {
  margin-top: 24rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx 18rpx;
  font-size: 28rpx;
}

.login-btn {
  margin-top: 20rpx;
  height: 80rpx;
  background-color: #CE1126 !important;
  color: #FFFFFF;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.login-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #999999;
  display: block;
}

.tabs {
  display: flex;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #EEEEEE;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 28rpx;
  color: #666666;
}

.tab.active {
  color: #CE1126;
  font-weight: 600;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background-color: #FFFFFF;
}

.filter {
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
  background-color: #F5F5F5;
  font-size: 22rpx;
  color: #999999;
}

.filter.on {
  background-color: #FFEBEE;
  color: #CE1126;
}

.list {
  height: calc(100vh - 180rpx);
  padding: 16rpx 24rpx 24rpx;
}

.item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.item-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.item-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.5;
}

.badge {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
}

.b1 { background-color: #E8F5E9; color: #009543; }
.b0 { background-color: #FFF8E1; color: #8D6E00; }
.b-1 { background-color: #FFEBEE; color: #CE1126; }

.item-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999999;
}

.dot { margin: 0 10rpx; }

.btn-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.btn {
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.btn.light { background-color: #F5F5F5; color: #333333; }
.btn.ok { background-color: #009543; color: #FFFFFF; }
.btn.warn { background-color: #FDCE12; color: #1A1A1A; }
.btn.danger { background-color: #CE1126; color: #FFFFFF; }

.empty, .load {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 26rpx;
}

