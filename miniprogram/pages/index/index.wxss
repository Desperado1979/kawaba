.page-home {
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #CE1126;
}

.search-inner {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 14rpx 24rpx;
  height: 68rpx;
}

.search-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-placeholder {
  font-size: 30rpx;
  color: #999999;
}

.location-tag {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  white-space: nowrap;
  font-weight: 500;
}

/* 轮播 */
.banner-swiper {
  width: 100%;
  height: 300rpx;
}

.banner-wrap {
  position: relative;
  width: 100%;
  height: 300rpx;
}

.banner-img {
  width: 100%;
  height: 300rpx;
}

.banner-title-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
}

.banner-title-text {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ========== 功能入口宫格 ========== */
.quick-grid {
  display: flex;
  justify-content: space-around;
  background-color: #FFFFFF;
  padding: 36rpx 16rpx 28rpx;
  margin-bottom: 16rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.icon-classifieds { background-color: #FFF3E0; }
.icon-yp { background-color: #E8F5E9; }
.icon-publish { background-color: #E3F2FD; }
.icon-my { background-color: #FCE4EC; }

.quick-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* ========== 资讯区标题 + 内联 Tab ========== */
.section-header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-right: 24rpx;
  white-space: nowrap;
}

.tabs-inline {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  gap: 12rpx;
}

.tab-tag {
  display: inline-block;
  padding: 8rpx 22rpx;
  font-size: 26rpx;
  color: #888888;
  background-color: #F5F5F5;
  border-radius: 24rpx;
  white-space: nowrap;
}

.tab-tag-active {
  color: #FFFFFF;
  background-color: #CE1126;
  font-weight: 600;
}

/* ========== 新闻列表 ========== */
.news-list {
  padding: 12rpx 24rpx;
  background-color: #FFFFFF;
}

.news-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.news-card:last-child {
  border-bottom: none;
}

.news-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 120rpx;
}

.news-title {
  font-size: 34rpx;
  color: #1A1A1A;
  line-height: 1.5;
  font-weight: 500;
}

.news-excerpt {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.news-source {
  font-size: 26rpx;
  color: #CE1126;
  margin-right: 20rpx;
}

.news-time {
  font-size: 26rpx;
  color: #999999;
}

.news-cover {
  width: 200rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 空状态 & 加载更多 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
}

.init-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: #FFFFFF;
  margin-bottom: 4rpx;
}

.init-btn {
  padding: 22rpx 56rpx;
  background-color: #CE1126;
  color: #FFFFFF;
  font-size: 30rpx;
  border-radius: 40rpx;
}

.init-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #CCCCCC;
  text-align: center;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999999;
}

/* 维护工具（隐藏） */
.maint-section {
  display: none;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
