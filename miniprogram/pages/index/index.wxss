.page-home {
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* ========== 搜索栏 ========== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #CE1126;
}

.search-inner {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 14rpx 24rpx;
  height: 68rpx;
}

.search-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-placeholder {
  font-size: 30rpx;
  color: #999999;
}

.location-tag {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  white-space: nowrap;
  font-weight: 500;
}

/* ========== 功能入口宫格 — 两排五列 ========== */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
  background-color: #FFFFFF;
  padding: 28rpx 0 20rpx;
}

.quick-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.quick-icon {
  width: 110rpx;
  height: 110rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-bottom: 10rpx;
}

.quick-label {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  text-align: center;
}

/* ========== 资讯区标题 + 内联 Tab ========== */
.section-header {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  background-color: #FFFFFF;
  margin-top: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-right: 24rpx;
  white-space: nowrap;
}

.tabs-inline {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  gap: 12rpx;
}

.tab-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  font-size: 28rpx;
  color: #888888;
  background-color: #F5F5F5;
  border-radius: 24rpx;
  white-space: nowrap;
}

.tab-tag-active {
  color: #FFFFFF;
  background-color: #CE1126;
  font-weight: 600;
}

/* ========== 新闻列表 ========== */
.news-list {
  padding: 0 24rpx;
  background-color: #FFFFFF;
}

.news-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.news-card:last-child {
  border-bottom: none;
}

.news-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 100rpx;
}

.news-title {
  font-size: 36rpx;
  color: #1A1A1A;
  line-height: 1.45;
  font-weight: 600;
}

.news-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.news-source {
  font-size: 28rpx;
  color: #CE1126;
  margin-right: 20rpx;
}

.news-time {
  font-size: 28rpx;
  color: #999999;
}

.news-cover {
  width: 200rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* ========== 其他 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
}

.init-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: #FFFFFF;
}

.init-btn {
  padding: 22rpx 56rpx;
  background-color: #CE1126;
  color: #FFFFFF;
  font-size: 30rpx;
  border-radius: 40rpx;
}

.init-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #CCCCCC;
  text-align: center;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999999;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
