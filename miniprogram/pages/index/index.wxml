<view class="page-home">
  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="goSearch">
    <view class="search-inner">
      <image class="search-icon" src="/images/icons/search.svg" mode="aspectFit" />
      <text class="search-placeholder">搜索新闻、分类、商家...</text>
    </view>
    <text class="location-tag">瓦努阿图</text>
  </view>

  <!-- 轮播 Banner -->
  <swiper class="banner-swiper" indicator-dots autoplay circular interval="{{4000}}" duration="{{500}}">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-wrap" bindtap="onBannerTap" data-item="{{item}}">
        <image class="banner-img" src="{{item.image}}" mode="aspectFill" />
        <view class="banner-title-overlay" wx:if="{{item.title}}">
          <text class="banner-title-text">{{item.title}}</text>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <!-- 数据初始化入口（云数据库无数据时显示） -->
  <view class="init-section" wx:if="{{!dataReady}}">
    <view class="init-btn" bindtap="onInitData">
      <text>一键写入示例数据</text>
    </view>
    <text class="init-tip">请先在云开发控制台创建集合: news, classifieds, businesses, users</text>
  </view>

  <!-- 新闻分类 Tab -->
  <scroll-view class="tabs-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tabs-row">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="tab-item {{currentCategory === item.key ? 'tab-active' : ''}}"
        bindtap="switchCategory"
        data-key="{{item.key}}"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 新闻列表 -->
  <view class="news-list">
    <view
      class="news-card"
      wx:for="{{newsList}}"
      wx:key="_id"
      bindtap="goNewsDetail"
      data-id="{{item._id}}"
    >
      <view class="news-content">
        <view class="news-title ellipsis-2">{{item.title}}</view>
        <view class="news-meta">
          <text class="news-source">{{item.source || 'Kavabar'}}</text>
          <text class="news-time">{{item.timeText}}</text>
          <text class="news-views">{{item.view_count || 0}}阅读</text>
        </view>
      </view>
      <image
        wx:if="{{item.cover_image}}"
        class="news-cover"
        src="{{item.cover_image}}"
        mode="aspectFill"
        lazy-load
      />
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && newsList.length === 0}}">
      <text class="empty-text">暂无新闻</text>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="load-more" wx:if="{{noMore && newsList.length > 0}}">
      <text>没有更多了</text>
    </view>
  </view>
</view>
