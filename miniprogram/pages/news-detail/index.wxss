.page-detail {
  background-color: #FFFFFF;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.article {
  padding: 32rpx;
}

.article-header {
  margin-bottom: 32rpx;
}

.article-title {
  font-size: 40rpx;
  color: #1A1A1A;
  font-weight: 600;
  line-height: 1.5;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  gap: 24rpx;
}

.meta-source {
  font-size: 24rpx;
  color: #CE1126;
}

.meta-time,
.meta-views {
  font-size: 24rpx;
  color: #999999;
}

.article-cover {
  width: 100%;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.article-body {
  font-size: 30rpx;
  color: #333333;
  line-height: 2;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 16rpx 32rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
}

.share-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #CE1126 !important;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.fav-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  color: #333333;
  font-size: 28rpx;
  border-radius: 36rpx;
}
