.page-classifieds {
  background-color: #F5F5F5;
  min-height: 100vh;
  position: relative;
}

/* 分类 Tab */
.tabs-scroll {
  background-color: #FFFFFF;
  white-space: nowrap;
  border-bottom: 1rpx solid #EEEEEE;
}

.tabs-row {
  display: inline-flex;
  padding: 16rpx 12rpx;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  color: #666666;
  position: relative;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.tab-active {
  color: #CE1126;
  font-weight: 600;
}

/* 列表 */
.list-scroll {
  height: calc(100vh - 160rpx);
}

.classified-list {
  padding: 16rpx 24rpx;
  padding-bottom: 120rpx;
}

.classified-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-category-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  color: #FFFFFF;
}

.tag-rent { background-color: #009543; }
.tag-job { background-color: #CE1126; }
.tag-secondhand { background-color: #FDCE12; color: #1A1A1A; }
.tag-service { background-color: #1A1A1A; }

.card-time {
  font-size: 22rpx;
  color: #999999;
}

.card-title {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 500;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.card-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-price {
  font-size: 32rpx;
  color: #CE1126;
  font-weight: 600;
}

.card-location {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #999999;
}

.loc-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
}

.card-images {
  display: flex;
  margin-top: 16rpx;
  gap: 12rpx;
}

.card-img {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
}

/* 发布按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #CE1126;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(206, 17, 38, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #999999;
}
