.page-profile {
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 头部 */
.profile-header {
  background: linear-gradient(135deg, #CE1126, #a00d1e);
  padding: 60rpx 32rpx 40rpx;
}

.user-section {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-default {
  background-color: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder {
  font-size: 48rpx;
  color: #FFFFFF;
}

.user-info {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

/* 统计 */
.stats-row {
  display: flex;
  background-color: #FFFFFF;
  margin: -20rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 30rpx 0;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  color: #1A1A1A;
  font-weight: 600;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 功能菜单 */
.menu-section {
  padding: 0 24rpx;
  margin-top: 24rpx;
}

.menu-group {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
}

button.menu-contact-btn {
  width: 100%;
  margin: 0;
  padding: 28rpx 24rpx;
  background-color: #ffffff;
  border: none;
  border-radius: 0;
  line-height: inherit;
  font-size: inherit;
  text-align: left;
}

button.menu-contact-btn::after {
  border: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon-wrap.bg-primary { background-color: #FFEBEE; }
.menu-icon-wrap.bg-gold { background-color: #FFF8E1; }
.menu-icon-wrap.bg-green { background-color: #E8F5E9; }

.menu-icon-text {
  font-size: 28rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.3;
}

.divider {
  height: 1rpx;
  background-color: #F0F0F0;
  margin-left: 100rpx;
}

/* 版本号 */
.version-text {
  text-align: center;
  font-size: 22rpx;
  color: #CCCCCC;
  padding: 40rpx 0;
}
