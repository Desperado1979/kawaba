<view class="page-detail">
  <view class="detail-card" wx:if="{{item}}">
    <!-- 图片轮播 -->
    <swiper class="img-swiper" wx:if="{{item.images && item.images.length > 0}}" indicator-dots circular>
      <swiper-item wx:for="{{item.images}}" wx:for-item="img" wx:key="*this">
        <image class="img-full" src="{{img}}" mode="aspectFill" />
      </swiper-item>
    </swiper>

    <view class="detail-body">
      <text class="detail-title">{{item.title}}</text>
      <view class="detail-price" wx:if="{{item.priceText}}">{{item.priceText}}</view>

      <view class="info-row">
        <text class="info-label">分类</text>
        <text class="info-value">{{item.categoryName}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">地点</text>
        <text class="info-value">{{item.location || '未填写'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">发布时间</text>
        <text class="info-value">{{item.timeText}}</text>
      </view>

      <view class="divider"></view>

      <view class="desc-section">
        <text class="desc-title">详细描述</text>
        <text class="desc-content">{{item.description || '暂无详细描述'}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar safe-bottom" wx:if="{{item.contact}}">
    <view class="contact-btn contact-btn-full" bindtap="callContact">
      <text>📞 联系发布者</text>
    </view>
  </view>
</view>
