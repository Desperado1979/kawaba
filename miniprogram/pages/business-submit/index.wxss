.page-submit {
  background-color: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 180rpx;
}

.form-section {
  padding: 16rpx 24rpx;
}

.form-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  font-size: 30rpx;
  color: #1A1A1A;
  height: 72rpx;
}

.form-textarea {
  font-size: 30rpx;
  color: #1A1A1A;
  width: 100%;
  min-height: 200rpx;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  font-size: 30rpx;
  color: #1A1A1A;
}

.placeholder { color: #CCCCCC; }
.picker-arrow { font-size: 36rpx; color: #CCCCCC; }

.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: #CE1126 !important;
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999999;
  text-align: center;
}

