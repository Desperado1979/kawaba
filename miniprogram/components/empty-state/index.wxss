.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
}

.empty-action {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background-color: #CE1126;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 36rpx;
}
