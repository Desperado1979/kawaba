.no-ugc {
  padding: 24rpx;
  min-height: 60vh;
}

.no-ugc-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
}

.no-ugc-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.no-ugc-p {
  display: block;
  font-size: 28rpx;
  color: #555555;
  line-height: 1.65;
  margin-bottom: 20rpx;
}

.no-ugc-strong {
  color: #1a1a1a;
  font-weight: 500;
}

.no-ugc-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ce1126;
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.no-ugc-btn::after {
  border: none;
}

.no-ugc-note {
  color: #444444;
  font-size: 26rpx;
}
